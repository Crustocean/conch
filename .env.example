# Crustocean connection
CRUSTOCEAN_API_URL=https://api.crustocean.chat
CONCH_AGENT_TOKEN=your-agent-token

# Join a specific agency (omit to join all member agencies)
# CONCH_AGENCY=my-coding-room

# Anthropic API key (required for Claude)
ANTHROPIC_API_KEY=your-anthropic-key

# Claude model override (default: claude-sonnet-4-20250514)
# Any Anthropic model with tool-use support works.
# CONCH_MODEL=claude-sonnet-4-20250514

# Default GitHub token — used as fallback when agencies don't provide their own.
#
# WARNING: In multi-tenant deployments, this single token serves ALL agencies.
# Any user who connects a repo in any agency gets read/write access via this
# token. Only set this for single-user self-hosting or development.
# For production multi-tenant use, require per-agency tokens instead:
#   /agent customize conch github_token ghp_... --agency
#
# GITHUB_TOKEN=ghp_your-github-token
